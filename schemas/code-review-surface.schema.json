{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tezit.com/spec/v1.2/code-review-surface.schema.json",
  "title": "Tez Code Review Surface",
  "description": "Schema for the surface object of a code review profile tez, per Code Review Profile v0.2.0 section 3.1. The surface summarizes the review: type, verdict, severity and observation counts, repository coordinates, and the parties involved.",
  "type": "object",
  "required": ["review_type", "verdict", "severity_summary", "finding_count", "repository", "reviewer", "author"],
  "properties": {
    "review_type": {
      "type": "string",
      "description": "Type of code review (Profile section 2).",
      "enum": ["pull_request", "commit_range", "file_set", "security_audit"],
      "examples": ["pull_request", "security_audit"]
    },
    "verdict": {
      "type": "string",
      "description": "Overall review verdict (Profile section 3.2). A review with any critical finding SHOULD NOT have a verdict of 'approved'.",
      "enum": ["approved", "changes_requested", "rejected", "informational"],
      "examples": ["changes_requested"]
    },
    "severity_summary": {
      "type": "object",
      "description": "Finding counts by severity level (Profile section 3.1).",
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 },
        "informational": { "type": "integer", "minimum": 0, "default": 0 }
      },
      "additionalProperties": false,
      "examples": [{ "critical": 0, "high": 2, "medium": 3, "low": 1, "informational": 2 }]
    },
    "observation_summary": {
      "type": "object",
      "description": "Finding counts by observation type (Profile sections 3.1 and 4.5). Added in v0.2.0. When omitted, 'issue' defaults to finding_count and the other types default to 0.",
      "properties": {
        "issue": { "type": "integer", "minimum": 0 },
        "praise": { "type": "integer", "minimum": 0 },
        "question": { "type": "integer", "minimum": 0 },
        "note": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false,
      "examples": [{ "issue": 6, "praise": 1, "question": 1, "note": 0 }]
    },
    "finding_count": {
      "type": "integer",
      "description": "Total number of findings in the review.",
      "minimum": 0,
      "examples": [8]
    },
    "repository": {
      "type": "string",
      "description": "Repository identifier or URL being reviewed.",
      "minLength": 1,
      "examples": ["acme/backend-api", "https://github.com/acme/backend-api"]
    },
    "branch": {
      "type": "string",
      "description": "Branch name under review.",
      "examples": ["feature/user-auth", "fix/sql-injection"]
    },
    "base_branch": {
      "type": "string",
      "description": "Base branch the change targets.",
      "examples": ["main"]
    },
    "commit_range": {
      "type": "string",
      "description": "Commit range under review.",
      "examples": ["a1b2c3d..e4f5a6b"]
    },
    "pull_request": {
      "type": "string",
      "description": "Pull request URL or identifier.",
      "examples": ["https://github.com/acme/backend-api/pull/142", "142"]
    },
    "languages": {
      "type": "array",
      "description": "Programming languages covered by the review.",
      "items": { "type": "string" },
      "examples": [["typescript", "python"]]
    },
    "files_reviewed": {
      "type": "integer",
      "description": "Number of files reviewed.",
      "minimum": 0,
      "examples": [14]
    },
    "lines_changed": {
      "type": "integer",
      "description": "Number of lines changed in the reviewed change set.",
      "minimum": 0,
      "examples": [486]
    },
    "reviewer": {
      "type": "object",
      "description": "The party who performed the review (Profile section 3.1).",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the reviewer.",
          "minLength": 1,
          "examples": ["Jane Smith", "Claude Code Review"]
        },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "description": "Role of the reviewer in this review.",
          "enum": ["reviewer", "author", "auditor"]
        },
        "type": {
          "type": "string",
          "description": "Whether the reviewer is a human, an AI, or a hybrid.",
          "enum": ["human", "ai", "hybrid"]
        }
      },
      "additionalProperties": false
    },
    "author": {
      "type": "object",
      "description": "The author of the code under review (Profile section 3.1).",
      "required": ["name", "role"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable name of the author.",
          "minLength": 1,
          "examples": ["Sam Patel"]
        },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "description": "Role of the author in this review.",
          "minLength": 1,
          "examples": ["author"]
        },
        "type": {
          "type": "string",
          "description": "Whether the author is a human, an AI, or a hybrid.",
          "enum": ["human", "ai", "hybrid"]
        }
      },
      "additionalProperties": false
    },
    "review_tools": {
      "type": "array",
      "description": "Tools used to produce or assist the review.",
      "items": { "type": "string" },
      "examples": [["eslint", "semgrep", "claude-code"]]
    }
  },
  "additionalProperties": false
}
